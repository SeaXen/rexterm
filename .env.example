REXTERM_PORT=2344
# Host mode listens on REXTERM_HOST_PORT/REXTERM_PORT. Docker maps REXTERM_PORT -> container REXTERM_BACKEND_PORT.
REXTERM_HOST_PORT=2344
REXTERM_BACKEND_PORT=8080
REXTERM_SHARED_TOKEN=change-me
REXTERM_AUTH_REQUIRED=1
REXTERM_AUTH_USERNAME=admin
# Prefer SHA256 hash over raw password. Generate with:
# python3 - <<'PY'
# import hashlib, getpass
# print(hashlib.sha256(getpass.getpass('Password: ').encode()).hexdigest())
# PY
REXTERM_AUTH_PASSWORD_SHA256=
# Raw password fallback if you do not use hash; avoid committing this.
REXTERM_AUTH_PASSWORD=
REXTERM_AUTH_SESSION_TTL=604800
